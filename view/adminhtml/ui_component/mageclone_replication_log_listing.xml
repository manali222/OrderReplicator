<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">mageclone_replication_log_listing.mageclone_replication_log_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <spinner>mageclone_replication_log_listing_columns</spinner>
        <deps>
            <dep>mageclone_replication_log_listing.mageclone_replication_log_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="mageclone_replication_log_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
        </settings>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="mageclone_replication_log_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>log_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="mageclone_replication_log_listing_columns">
        <column name="log_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Log ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>

        <column name="source_increment_id" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Source Order #</label>
            </settings>
        </column>

        <column name="new_increment_id" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">New Order #</label>
            </settings>
        </column>

        <column name="customer_email" sortOrder="40">
            <settings>
                <filter>text</filter>
                <label translate="true">Customer Email</label>
            </settings>
        </column>

        <column name="status" sortOrder="50">
            <settings>
                <filter>select</filter>
                <label translate="true">Status</label>
                <dataType>select</dataType>
            </settings>
        </column>

        <column name="error_message" sortOrder="60">
            <settings>
                <label translate="true">Error</label>
            </settings>
        </column>

        <column name="csv_filename" sortOrder="70">
            <settings>
                <filter>text</filter>
                <label translate="true">CSV File</label>
            </settings>
        </column>

        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date" sortOrder="80">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Created At</label>
                <dataType>date</dataType>
            </settings>
        </column>
    </columns>
</listing>
