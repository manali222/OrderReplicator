<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="MageClone_OrderReplicator::order_replicator"
                          title="Order Replicator"
                          sortOrder="100">
                    <resource id="MageClone_OrderReplicator::view"
                              title="View Orders for Replication"
                              sortOrder="10"/>
                    <resource id="MageClone_OrderReplicator::replicate"
                              title="Replicate Orders"
                              sortOrder="20"/>
                    <resource id="MageClone_OrderReplicator::csv_upload"
                              title="CSV Upload"
                              sortOrder="30"/>
                    <resource id="MageClone_OrderReplicator::config"
                              title="Configuration"
                              sortOrder="40"/>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
